# =============================================================================
# Nanobot 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# =============================================================================

# 注意：可以同时启用多个频道，通过 ./deploy.sh channels 管理

# -----------------------------------------------------------------------------
# 钉钉频道
# 来源：钉钉开放平台 -> 应用详情 -> AppKey / AppSecret
# 文档：https://open.dingtalk.com/
# -----------------------------------------------------------------------------
NANOBOT_CHANNELS__DINGTALK__ENABLED=false
NANOBOT_CHANNELS__DINGTALK__CLIENT_ID=your_dingtalk_app_key
NANOBOT_CHANNELS__DINGTALK__CLIENT_SECRET=your_dingtalk_app_secret

# -----------------------------------------------------------------------------
# 飞书频道
# 来源：飞书开放平台 -> 应用管理 -> App ID / App Secret
# 文档：https://open.feishu.cn/
# 优势：无需公网 IP，使用 WebSocket 长连接接收事件
# -----------------------------------------------------------------------
NANOBOT_CHANNELS__FEISHU__ENABLED=false
NANOBOT_CHANNELS__FEISHU__APP_ID=your_feishu_app_id
NANOBOT_CHANNELS__FEISHU__APP_SECRET=your_feishu_app_secret
# NANOBOT_CHANNELS__FEISHU__ENCRYPT_KEY=your_encrypt_key
# NANOBOT_CHANNELS__FEISHU__VERIFICATION_TOKEN=your_verification_token

# -----------------------------------------------------------------------------
# LLM 提供商 API Key（填写你使用的那个即可）
# -----------------------------------------------------------------------------
NANOBOT_PROVIDERS__OPENROUTER__API_KEY=your_openrouter_api_key
# NANOBOT_PROVIDERS__ANTHROPIC__API_KEY=your_anthropic_api_key
# NANOBOT_PROVIDERS__OPENAI__API_KEY=your_openai_api_key
# NANOBOT_PROVIDERS__DEEPSEEK__API_KEY=your_deepseek_api_key
# NANOBOT_PROVIDERS__MINIMAX__API_KEY=your_minimax_api_key

# -----------------------------------------------------------------------------
# 舆情监控 - Supabase
# 来源：Supabase 控制台 -> Project Settings -> API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_secret_key
